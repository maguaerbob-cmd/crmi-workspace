{
  "entities": {
    "Department": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Department",
      "type": "object",
      "description": "Represents an organizational department within the CRMI system. Departments are predefined and categorize tasks and users.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Department entity."
        },
        "name": {
          "type": "string",
          "description": "The official name of the department."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores information about a user, including their name, email, assigned role, and department.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (Firebase UID)."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The user's assigned role (owner, director, deputy_director, head, inspector, reader)."
        },
        "departmentId": {
          "type": "string",
          "description": "Reference to the department the user belongs to."
        },
        "isApproved": {
          "type": "boolean",
          "description": "Whether the user's account has been approved by an administrator."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "departmentId"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a single task, event, or outing.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Task."
        },
        "title": {
          "type": "string",
          "description": "Title of the task."
        },
        "dateTime": {
          "type": "string",
          "description": "Scheduled date and time.",
          "format": "date-time"
        },
        "place": {
          "type": "string",
          "description": "Location of the task."
        },
        "description": {
          "type": "string",
          "description": "Detailed description."
        },
        "checklist": {
          "type": "array",
          "description": "List of checklist items with status.",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "done": { "type": "boolean" }
            }
          }
        },
        "priority": {
          "type": "string",
          "description": "Priority level (срочно, не срочно)."
        },
        "status": {
          "type": "string",
          "description": "Current status (запланировано, в процессе, завершено)."
        },
        "departmentId": {
          "type": "string",
          "description": "Department assigned to this task."
        },
        "responsibleUserId": {
          "type": "string",
          "description": "UID of the user responsible for the task."
        },
        "createdBy": {
          "type": "string",
          "description": "UID of the task creator."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "title",
        "dateTime",
        "place",
        "status",
        "departmentId",
        "createdBy"
      ]
    },
    "AppSetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppSetting",
      "type": "object",
      "description": "Global application settings such as branding and configuration.",
      "properties": {
        "logoURL": {
          "type": "string",
          "description": "Base64 encoded logo image or URL for branding."
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/departments/{departmentId}",
        "definition": {
          "entityName": "Department",
          "schema": {
            "$ref": "#/backend/entities/Department"
          },
          "description": "Stores predefined organizational departments.",
          "params": [
            { "name": "departmentId", "description": "Unique identifier for a department." }
          ]
        }
      },
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profiles including roles and approval status.",
          "params": [
            { "name": "userId", "description": "Firebase UID." }
          ]
        }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": {
            "$ref": "#/backend/entities/Task"
          },
          "description": "A collection storing all tasks and outings.",
          "params": [
            { "name": "taskId", "description": "Unique identifier for a task." }
          ]
        }
      },
      {
        "path": "/settings/{settingId}",
        "definition": {
          "entityName": "AppSetting",
          "schema": {
            "$ref": "#/backend/entities/AppSetting"
          },
          "description": "Global application settings (e.g. 'app' document for logo). Publicly readable.",
          "params": [
            { "name": "settingId", "description": "Unique identifier (e.g., 'app')." }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure now includes a 'settings' collection to allow global branding data (like a logo) to be fetched by unauthenticated users during the login process, while restricting write access to global administrators (Owner)."
  }
}