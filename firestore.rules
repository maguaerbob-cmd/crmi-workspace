
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CRMI TaskFlow Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && currentUserData().role == role;
    }

    function isGlobalAdmin() {
      let data = currentUserData();
      return hasRole('owner') || 
             hasRole('director') || 
             hasRole('deputy_director') ||
             data.departmentId == 'technical-service-center' || 
             data.departmentId == 'media-center';
    }

    // --- Collection Rules ---

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isGlobalAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isGlobalAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isGlobalAdmin()) && resource != null;
      allow delete: if isGlobalAdmin() && resource != null;
    }

    match /settings/{settingId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow update: if isGlobalAdmin();
      allow create, delete: if isGlobalAdmin();
    }

    match /tasks/{taskId} {
      // Пользователи видят задачи своего отдела или все, если они админы
      allow get, list: if isGlobalAdmin() || (isSignedIn() && currentUserData().departmentId == resource.data.departmentId);
      
      // Создавать может любой авторизованный, но данные должны быть корректны
      allow create: if isSignedIn() && 
                    request.resource.data.createdBy == request.auth.uid &&
                    (isGlobalAdmin() || request.resource.data.departmentId == currentUserData().departmentId);
      
      // Редактирование: создатель, админ или начальник отдела
      allow update: if resource != null && (
        isGlobalAdmin() || 
        (currentUserData().departmentId == resource.data.departmentId && (
          hasRole('head') || 
          resource.data.createdBy == request.auth.uid || 
          resource.data.responsibleUserId == request.auth.uid
        ))
      );
      
      allow delete: if resource != null && (
        isGlobalAdmin() || 
        resource.data.createdBy == request.auth.uid
      );
    }
  }
}
