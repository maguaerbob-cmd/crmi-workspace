rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isOwner(authData) {
      return authData != null && authData.role == 'owner';
    }

    // Коллекция пользователей
    match /userProfiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isOwner(getAuthData()));
      allow list: if isSignedIn() && isOwner(getAuthData());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (isOwner(getAuthData()) || request.auth.uid == userId);
      allow delete: if isSignedIn() && isOwner(getAuthData());
    }

    // Коллекция задач: доступна для чтения всем авторизованным пользователям
    // Это исправляет ошибку Missing or insufficient permissions при общих запросах
    match /tasks/{taskId} {
      allow read, list: if isSignedIn();

      // Создание: любой авторизованный пользователь (по умолчанию роль читателя, но правила позволяют создавать)
      allow create: if isSignedIn();

      // Обновление: владелец или если задача не завершена (для смены статуса)
      allow update: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (resource.data.status != 'завершено' && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'checklist']))
      );

      // Удаление: только владелец
      allow delete: if isSignedIn() && isOwner(getAuthData());
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}