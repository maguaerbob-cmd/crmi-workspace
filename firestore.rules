rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * СТРОГИЕ ПРАВИЛА ДОСТУПА CRMI
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    // Глобальный доступ: Владелец или спец. отделы
    function hasGlobalAccess(authData) {
      return authData != null && (
        authData.role == 'owner' || 
        authData.departmentId == 'technical-service-center' || 
        authData.departmentId == 'media-center'
      );
    }

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn() && (request.auth.uid == userId || hasGlobalAccess(getAuthData()));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        hasGlobalAccess(getAuthData()) || 
        (getAuthData().role == 'head' && getAuthData().departmentId == resource.data.departmentId)
      );
      allow delete: if isSignedIn() && hasGlobalAccess(getAuthData()) && getAuthData().role == 'owner';
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /tasks/{taskId} {
      
      function canRead(authData, taskData) {
        return hasGlobalAccess(authData) || authData.departmentId == taskData.departmentId;
      }

      // Доступ на чтение
      allow get: if isSignedIn() && canRead(getAuthData(), resource.data);
      // Для list важно, чтобы запрос на клиенте содержал фильтр по departmentId (для не-админов)
      allow list: if isSignedIn() && (hasGlobalAccess(getAuthData()) || getAuthData().departmentId == resource.data.departmentId);
      
      allow create: if isSignedIn() && (
        hasGlobalAccess(getAuthData()) || 
        ((getAuthData().role == 'head' || getAuthData().role == 'inspector') && getAuthData().departmentId == request.resource.data.departmentId)
      );
      
      allow update: if isSignedIn() && (
        hasGlobalAccess(getAuthData()) || 
        (getAuthData().role == 'head' && getAuthData().departmentId == resource.data.departmentId) || 
        (request.auth.uid == resource.data.responsibleUserId && resource.data.status != 'завершено')
      );
      
      allow delete: if isSignedIn() && (
        hasGlobalAccess(getAuthData()) || 
        (getAuthData().role == 'head' && getAuthData().departmentId == resource.data.departmentId)
      );
    }
  }
}