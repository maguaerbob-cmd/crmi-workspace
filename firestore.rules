
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CRMI TaskFlow Security Rules
     * Редакция: 2024-05-24 (Публичный доступ и автоматическое одобрение)
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return isSignedIn() ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data : null;
    }

    function isGlobalAdmin(userData) {
      return userData != null && (
        userData.role == 'owner' || 
        userData.role == 'director' || 
        userData.role == 'deputy_director' ||
        userData.departmentId == 'technical-service-center' || 
        userData.departmentId == 'media-center'
      );
    }

    // --- Collection Rules ---

    match /departments/{departmentId} {
      // Открыто для всех для отображения названий отделов в карточках
      allow read: if true;
      allow write: if isSignedIn() && isGlobalAdmin(getUserData());
    }

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isGlobalAdmin(getUserData());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isGlobalAdmin(getUserData()));
      allow delete: if isSignedIn() && isGlobalAdmin(getUserData());
    }

    match /settings/{settingId} {
      // Открыто для всех (логотип и общие настройки)
      allow read: if true;
      allow write: if isSignedIn() && isGlobalAdmin(getUserData());
    }

    match /tasks/{taskId} {
      // Полный публичный доступ на чтение для всех посетителей
      allow read: if true;
      
      allow create: if isSignedIn() && 
                    let userData = getUserData();
                    request.resource.data.createdBy == request.auth.uid &&
                    (isGlobalAdmin(userData) || request.resource.data.departmentId == userData.departmentId);
      
      allow update: if isSignedIn() && 
                    let userData = getUserData();
                    (isGlobalAdmin(userData) || (
                      userData.departmentId == resource.data.departmentId && (
                        userData.role == 'head' || 
                        resource.data.createdBy == request.auth.uid || 
                        resource.data.responsibleUserId == request.auth.uid
                      )
                    ));
      
      allow delete: if isSignedIn() && 
                    let userData = getUserData();
                    (isGlobalAdmin(userData) || (
                      resource.data.createdBy == request.auth.uid && 
                      resource.data.status != 'завершено'
                    ));
    }
  }
}
