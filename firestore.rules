rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isOwner() {
      let profile = getUserProfile();
      return profile != null && profile.role == 'owner';
    }

    // Коллекция профилей пользователей
    match /userProfiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isOwner());
      
      // Список сотрудников доступен всем авторизованным (для выбора ответственных),
      // реальная фильтрация по отделам происходит в коде
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isOwner() || 
        (getUserProfile().role == 'head' && getUserProfile().departmentId == resource.data.departmentId)
      );
      
      allow delete: if isSignedIn() && isOwner();
    }

    // Коллекция задач
    match /tasks/{taskId} {
      // Чтение: Владелец видит всё. Остальные видят незавершенные задачи организации.
      allow read, list: if isSignedIn() && (
        isOwner() || 
        resource.data.status != 'завершено'
      );

      // Создание: Владелец, Руководитель, Инспектор
      allow create: if isSignedIn() && (
        isOwner() || 
        getUserProfile().role == 'head' || 
        getUserProfile().role == 'inspector'
      );

      // Обновление: Владелец, Руководитель (свой отдел), Инспектор (свои/ответственный), Читатель (статус в своем отделе)
      allow update: if isSignedIn() && (
        isOwner() || 
        (getUserProfile().role == 'head' && resource.data.departmentId == getUserProfile().departmentId) ||
        (getUserProfile().role == 'inspector' && (resource.data.responsibleUserId == request.auth.uid || resource.data.createdBy == request.auth.uid)) ||
        (getUserProfile().role == 'reader' && resource.data.departmentId == getUserProfile().departmentId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'checklist'])) ||
        (resource.data.responsibleUserId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'checklist']))
      );

      allow delete: if isSignedIn() && isOwner();
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}