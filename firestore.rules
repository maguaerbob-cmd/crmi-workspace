
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CRMI TaskFlow Security Rules - Optimized
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Получаем данные профиля текущего пользователя
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    // Проверка на права глобального администратора (управление всей организацией)
    function isGlobalAdmin(userData) {
      return userData.role == 'owner' || 
             userData.role == 'director' || 
             userData.role == 'deputy_director' ||
             userData.departmentId == 'technical-service-center' || 
             userData.departmentId == 'media-center';
    }

    // --- Collection Rules ---

    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isGlobalAdmin(getUserData());
    }

    match /userProfiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isGlobalAdmin(getUserData());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isGlobalAdmin(getUserData()));
      allow delete: if isSignedIn() && isGlobalAdmin(getUserData());
    }

    match /settings/{settingId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isSignedIn() && isGlobalAdmin(getUserData());
    }

    match /tasks/{taskId} {
      // Чтение задач: глобальные админы видят всё, остальные — только задачи своего отдела
      allow read: if isSignedIn() && (
        let userData = getUserData();
        isGlobalAdmin(userData) || (userData.departmentId == resource.data.departmentId)
      );
      
      // Создание задачи: авторство должно быть верным, отдел должен совпадать (кроме админов)
      allow create: if isSignedIn() && 
                    let userData = getUserData();
                    request.resource.data.createdBy == request.auth.uid &&
                    (isGlobalAdmin(userData) || request.resource.data.departmentId == userData.departmentId);
      
      // Редактирование: создатель, ответственный, начальник отдела или админ
      allow update: if isSignedIn() && 
                    let userData = getUserData();
                    (isGlobalAdmin(userData) || (
                      userData.departmentId == resource.data.departmentId && (
                        userData.role == 'head' || 
                        resource.data.createdBy == request.auth.uid || 
                        resource.data.responsibleUserId == request.auth.uid
                      )
                    ));
      
      // Удаление: создатель (если не завершена) или админ
      allow delete: if isSignedIn() && 
                    let userData = getUserData();
                    (isGlobalAdmin(userData) || (
                      resource.data.createdBy == request.auth.uid && 
                      resource.data.status != 'завершено'
                    ));
    }
  }
}
