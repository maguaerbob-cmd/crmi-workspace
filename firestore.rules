rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isOwner(authData) {
      return authData != null && authData.role == 'owner';
    }

    function isGlobalDept(authData) {
      return authData != null && (authData.departmentId == 'media-center' || authData.departmentId == 'technical-service-center');
    }

    match /userProfiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isOwner(getAuthData()));
      allow list: if isSignedIn() && isOwner(getAuthData());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'departmentId']))
      );
      allow delete: if isSignedIn() && isOwner(getAuthData());
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        isOwner(getAuthData()) || 
        isGlobalDept(getAuthData()) || 
        (getAuthData().departmentId == resource.data.departmentId && resource.data.status != 'завершено')
      );

      allow create: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (getAuthData().role in ['head', 'inspector'] && request.resource.data.departmentId == getAuthData().departmentId)
      );

      allow update: if isSignedIn() && (
        isOwner(getAuthData()) || (
          resource.data.status != 'завершено' && (
            (getAuthData().role == 'head' && getAuthData().departmentId == resource.data.departmentId) ||
            (getAuthData().role == 'inspector' && request.auth.uid == resource.data.responsibleUserId) ||
            (getAuthData().role == 'reader' && getAuthData().departmentId == resource.data.departmentId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
          )
        )
      );

      allow delete: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (getAuthData().role == 'head' && getAuthData().departmentId == resource.data.departmentId)
      );
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}