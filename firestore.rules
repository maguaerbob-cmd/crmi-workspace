rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }

    // Профили пользователей: чтение доступно всем сотрудникам для координации
    match /userProfiles/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'owner'
      );
      // Только владелец может удалять профили сотрудников
      allow delete: if isSignedIn() && 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'owner';
    }

    // Задачи: чтение открыто для всех сотрудников организации
    match /tasks/{taskId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'owner';
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}