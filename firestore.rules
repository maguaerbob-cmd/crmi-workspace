rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isNotReader() {
      return getUserData().role != 'reader';
    }

    // Профили пользователей
    match /userProfiles/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        getUserData().role == 'owner'
      );
      allow delete: if isSignedIn() && getUserData().role == 'owner';
    }

    // Задачи
    match /tasks/{taskId} {
      allow read, list: if isSignedIn();
      
      // Читатель не может создавать или изменять задачи
      allow create: if isSignedIn() && isNotReader();
      
      allow update: if isSignedIn() && isNotReader() && (
        getUserData().role == 'owner' || 
        request.auth.uid == resource.data.createdBy || 
        request.auth.uid == resource.data.responsibleUserId ||
        (getUserData().role == 'head' && getUserData().departmentId == resource.data.departmentId)
      );
      
      // Логика удаления:
      // 1. Владелец может все
      // 2. Создатель или Руководитель отдела (не читатели) могут удалять только НЕ завершенные задачи
      allow delete: if isSignedIn() && isNotReader() && (
        getUserData().role == 'owner' || 
        (
          (request.auth.uid == resource.data.createdBy || 
           (getUserData().role == 'head' && getUserData().departmentId == resource.data.departmentId)) &&
          resource.data.status != 'завершено'
        )
      );
    }

    match /databases/{database}/documents/userProfiles/{uid} {
      // Это правило дублирует основное, но помогает при сложных запросах
      allow read: if isSignedIn();
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}