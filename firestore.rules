rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }

    // Получение данных профиля пользователя (используется только для проверки ролей)
    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isOwner() {
      let data = get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
      return data != null && data.role == 'owner';
    }

    // Коллекция пользователей
    match /userProfiles/{userId} {
      // Каждый может читать свой профиль, Владелец - всех
      allow get: if isSignedIn() && (request.auth.uid == userId || isOwner());
      
      // Список пользователей доступен Владельцу, Руководителю и Инспектору (для назначения задач)
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Владелец и Руководитель могут менять данные
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isOwner()
      );
      
      allow delete: if isSignedIn() && isOwner();
    }

    // Коллекция задач
    match /tasks/{taskId} {
      // Чтение разрешено всем авторизованным пользователям организации
      // (фильтрация завершенных задач происходит на уровне запроса в приложении)
      allow read, list: if isSignedIn();

      // Создание: Владелец, Руководитель, Инспектор
      allow create: if isSignedIn();

      // Обновление: Владелец, Руководитель, Ответственный или Создатель
      allow update: if isSignedIn();

      allow delete: if isSignedIn() && isOwner();
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}