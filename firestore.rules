
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isApproved() {
      let data = getUserData();
      return data.isApproved == true || data.role == 'owner';
    }

    function isGlobalManager() {
      let role = getUserData().role;
      return role == 'owner' || role == 'director' || role == 'deputy_director';
    }

    match /userProfiles/{userId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        getUserData().role == 'owner'
      );
      allow delete: if isSignedIn() && getUserData().role == 'owner';
    }

    match /tasks/{taskId} {
      allow read, list: if isSignedIn() && isApproved();
      
      allow create: if isSignedIn() && isApproved() && getUserData().role != 'reader';
      
      allow update: if isSignedIn() && isApproved() && getUserData().role != 'reader' && (
        isGlobalManager() || 
        request.auth.uid == resource.data.createdBy || 
        request.auth.uid == resource.data.responsibleUserId ||
        (getUserData().role == 'head' && getUserData().departmentId == resource.data.departmentId)
      );
      
      allow delete: if isSignedIn() && isApproved() && getUserData().role != 'reader' && (
        isGlobalManager() || 
        (
          (request.auth.uid == resource.data.createdBy || 
           (getUserData().role == 'head' && getUserData().departmentId == resource.data.departmentId)) &&
          resource.data.status != 'завершено'
        )
      );
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}
