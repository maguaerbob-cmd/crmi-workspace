rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * Enforces RBAC and DBAC for the CRMI platform.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isGlobalAdmin() {
      return isSignedIn() && getAuthData().role == 'owner';
    }

    function isSpecialDepartment() {
      let authData = getAuthData();
      return isSignedIn() && (authData.departmentId == 'technical-service-center' || authData.departmentId == 'media-center');
    }

    function isUserInDepartment(deptId) {
      return isSignedIn() && getAuthData().departmentId == deptId;
    }

    function hasRole(role) {
      return isSignedIn() && getAuthData().role == role;
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list: if isOwner(userId) || isGlobalAdmin();
      allow create: if isOwner(userId);
      allow update: if (resource != null && isOwner(userId)) || isGlobalAdmin() || (hasRole('head') && isUserInDepartment(resource.data.departmentId));
      allow delete: if resource != null && isGlobalAdmin();
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /tasks/{taskId} {
      
      function canReadTask(data) {
        let authData = getAuthData();
        return authData.role == 'owner' || 
               authData.departmentId == 'technical-service-center' || 
               authData.departmentId == 'media-center' || 
               (authData.departmentId == data.departmentId && data.status != 'завершено');
      }

      function canModifyTask(data) {
        let authData = getAuthData();
        return authData.role == 'owner' || (authData.role == 'head' && authData.departmentId == data.departmentId);
      }

      function canCreateTask(data) {
        let authData = getAuthData();
        return authData.role == 'owner' || ((authData.role == 'head' || authData.role == 'inspector') && authData.departmentId == data.departmentId);
      }

      allow get: if canReadTask(resource.data);
      
      // Исправлено: для корректной работы запросов list правила должны проверять данные документа (resource.data)
      allow list: if isSignedIn() && (
        isGlobalAdmin() || 
        isSpecialDepartment() || 
        (resource.data.departmentId == getAuthData().departmentId)
      );
      
      allow create: if canCreateTask(request.resource.data);
      allow update: if resource != null && (canModifyTask(resource.data) || (isOwner(resource.data.responsibleUserId) && resource.data.status != 'завершено'));
      allow delete: if resource != null && canModifyTask(resource.data);
    }
  }
}