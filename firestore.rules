rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isOwner(authData) {
      return authData != null && authData.role == 'owner';
    }

    // Коллекция пользователей
    match /userProfiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isOwner(getAuthData()));
      
      // Позволяем листинг, если пользователь владелец ИЛИ если это руководитель, фильтрующий по своему отделу
      allow list: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (getAuthData().role == 'head' && resource.data.departmentId == getAuthData().departmentId)
      );
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow update: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (getAuthData().role == 'head' && resource.data.departmentId == getAuthData().departmentId) ||
        request.auth.uid == userId
      );
      
      allow delete: if isSignedIn() && isOwner(getAuthData());
    }

    // Коллекция задач
    match /tasks/{taskId} {
      // Все авторизованные пользователи могут видеть список задач (как просил пользователь)
      allow read, list: if isSignedIn();

      allow create: if isSignedIn();

      // Обновление разрешено, если задача не завершена, или если это делает владелец
      allow update: if isSignedIn() && (
        isOwner(getAuthData()) || 
        (resource.data.status != 'завершено' || request.resource.data.status == 'завершено')
      );

      allow delete: if isSignedIn() && isOwner(getAuthData());
    }

    match /departments/{deptId} {
      allow read: if isSignedIn();
    }
  }
}