rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * Enforces RBAC and DBAC for the CRMI platform.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getAuthData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getAuthData().role == role;
    }

    function isGlobalAdmin() {
      return hasRole('owner');
    }

    function isSpecialDepartment() {
      return isSignedIn() && (getAuthData().departmentId == 'technical-service-center' || getAuthData().departmentId == 'media-center');
    }

    function isUserInDepartment(deptId) {
      return isSignedIn() && getAuthData().departmentId == deptId;
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list: if isOwner(userId) || isGlobalAdmin();
      allow create: if isOwner(userId);
      allow update: if (resource != null && isOwner(userId)) || isGlobalAdmin() || (hasRole('head') && isUserInDepartment(resource.data.departmentId));
      allow delete: if resource != null && isGlobalAdmin();
    }

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /tasks/{taskId} {
      
      function canReadTask(data) {
        return isGlobalAdmin() || isSpecialDepartment() || (isUserInDepartment(data.departmentId) && data.status != 'завершено');
      }

      function canModifyTask(data) {
        return isGlobalAdmin() || (hasRole('head') && isUserInDepartment(data.departmentId));
      }

      function canCreateTask(data) {
        return isGlobalAdmin() || ((hasRole('head') || hasRole('inspector')) && isUserInDepartment(data.departmentId));
      }

      allow get: if canReadTask(resource.data);
      allow list: if isGlobalAdmin() || isSpecialDepartment() || isUserInDepartment(getAuthData().departmentId);
      allow create: if canCreateTask(request.resource.data);
      allow update: if resource != null && (canModifyTask(resource.data) || (isOwner(resource.data.responsibleUserId) && resource.data.status != 'завершено'));
      allow delete: if resource != null && canModifyTask(resource.data);
    }
  }
}